---
import Layout from "../layouts/Layout.astro";
import { schemaBreadcrumb, schemaFAQ, SITE } from "../lib/seo";

const faqs = [
  {
    question: "Como posso importar os vinhos Palato do Côa para o Brasil?",
    answer: "Entre em contato através do nosso formulário ou e-mail brasil@palatodocoa.pt. Trabalhamos com importadoras homologadas e podemos indicar parceiros logísticos para o processo de importação.",
  },
  {
    question: "Qual é o volume mínimo para pedidos de atacado?",
    answer: "O volume mínimo e as condições específicas são definidos conforme o perfil do parceiro (restaurante, importadora, adega). Entre em contato para receber uma proposta personalizada.",
  },
  {
    question: "Vocês oferecem exclusividade regional?",
    answer: "Sim, analisamos propostas de exclusividade regional para distribuidores e importadoras comprometidos com o desenvolvimento da marca no Brasil.",
  },
  {
    question: "É possível visitar a quinta no Douro Superior?",
    answer: "Sim. Temos um programa exclusivo para parceiros brasileiros que inclui visita guiada à Quinta da Saudade, prova guiada e reunião comercial. Consulte disponibilidade.",
  },
];

const schemas = [
  schemaBreadcrumb([{ name: "Início", url: "/" }, { name: "Para o Brasil", url: "/para-o-brasil" }]),
  schemaFAQ(faqs),
];
---
<Layout
  title="Palato do Côa no Brasil - Atacado para Restaurantes e Importadoras"
  description="Condições especiais de atacado para importadoras, distribuidores, restaurantes e adegas. Suporte completo com fichas técnicas, fotos, treinamento e exclusividade regional."
  keywords={`${SITE.keywords.b2b}, vinho português para restaurante, como importar vinho portugal brasil, vinho douro exclusivo brasil`}
  schema={schemas}
>
  <section class="py-20 px-6 border-b border-[var(--color-border)] text-center">
    <p class="section-subtitle">Vinho Douro Superior Atacado</p>
    <h1 class="font-serif text-4xl md:text-5xl text-[var(--color-dark)] mb-4">
      Pronto para levar o Douro Superior ao seu negócio?
    </h1>
    <div class="divider-gold mx-auto"></div>
  </section>

  <section class="py-16 px-6 max-w-5xl mx-auto">

    <!-- Vantagens para Parceiros -->
    <div class="text-center mb-12">
      <p class="section-subtitle">Vantagens para Parceiros</p>
      <h2 class="font-serif text-3xl">Por que distribuir Palato do Côa no Brasil</h2>
      <div class="divider-gold mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">
      {[
        {
          icon: "🍽️",
          title: "Restaurantes e Chefs",
          text: "Diferenciação real na carta de vinhos. Vinhos do Douro Superior com história, terroir único e enólogos identificados — o storytelling que os seus clientes vão lembrar e recomendar.",
        },
        {
          icon: "🏢",
          title: "Importadoras e Distribuidores",
          text: "Exclusividade e parceria de longo prazo. Trabalhamos com quem partilha a nossa visão de qualidade e autenticidade no mercado premium brasileiro.",
        },
        {
          icon: "🍾",
          title: "Adegas e Lojas Especializadas",
          text: "Rótulos que se vendem pela história. Fichas técnicas completas, material visual profissional e suporte para formação da equipe de vendas.",
        },
        {
          icon: "🥂",
          title: "Hotéis e Eventos Premium",
          text: "Para quem quer elevar a experiência dos hóspedes e convidados com vinhos portugueses autênticos, directo do produtor do Douro Superior.",
        },
      ].map((item) => (
        <div class="flex gap-5 p-8 border border-[var(--color-border)] hover:border-[var(--color-gold)] transition-colors bg-white">
          <div class="text-3xl flex-shrink-0">{item.icon}</div>
          <div>
            <h3 class="font-serif text-xl mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.text}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Como se Tornar Parceiro -->
    <div class="bg-[var(--color-dark)] text-white p-10 md:p-14 mb-20">
      <p class="section-subtitle text-[var(--color-gold)]">Como se Tornar Parceiro</p>
      <h2 class="font-serif text-3xl mb-6">O que está incluído na parceria</h2>
      <div class="divider-gold mb-8"></div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        {[
          "Condições especiais de atacado para vinho douro superior",
          "Logística dedicada e suporte à importação",
          "Fichas técnicas completas em PT-BR",
          "Fotos profissionais das garrafas em alta resolução",
          "Treinamento de equipe (presencial ou online)",
          "Conteúdo para redes sociais pronto para usar",
          "Suporte directo com os enólogos Carloto e Paulo",
          "Programa exclusivo de visita à Quinta da Saudade",
        ].map((item) => (
          <div class="flex items-center gap-3">
            <span class="text-[var(--color-gold)] text-lg flex-shrink-0">→</span>
            <span class="text-sm text-gray-300">{item}</span>
          </div>
        ))}
      </div>
      <a href="/contato" class="btn-secondary inline-block">Solicitar proposta comercial</a>
    </div>

    <!-- FAQ com Schema.org -->
    <div class="mb-20">
      <div class="text-center mb-10">
        <p class="section-subtitle">Dúvidas frequentes</p>
        <h2 class="font-serif text-3xl">Perguntas sobre importação e atacado</h2>
        <div class="divider-gold mx-auto mt-4"></div>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="border border-[var(--color-border)] group">
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
              <h3 class="font-serif text-lg pr-4">{faq.question}</h3>
              <span class="text-[var(--color-gold)] text-xl flex-shrink-0 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-6 pb-6">
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- CTA final -->
    <div class="text-center border-t border-[var(--color-border)] pt-16">
      <p class="section-subtitle">Próximo passo</p>
      <h2 class="font-serif text-3xl mb-4">Vamos conversar?</h2>
      <p class="text-sm text-[var(--color-muted)] max-w-md mx-auto mb-8">
        Estamos aqui para atender você com a mesma dedicação que colocamos em cada garrafa.
        Respondemos em até 48 horas úteis.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/contato" class="btn-secondary">Fale com nossa equipe</a>
        <a
          href="https://wa.me/351960000000?text=Olá,%20tenho%20interesse%20nos%20vinhos%20Palato%20do%20Côa%20para%20o%20Brasil."
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 px-6 py-3 bg-[#25D366] text-white text-xs uppercase tracking-widest font-medium hover:bg-[#1ebe5d] transition-colors"
        >
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a href="/vinhos" class="btn-primary">Ver fichas técnicas dos vinhos</a>
      </div>
    </div>
  </section>
</Layout>
