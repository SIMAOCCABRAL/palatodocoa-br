---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ui/ContactForm.astro";
import { schemaBreadcrumb } from "../lib/seo";

const schema = schemaBreadcrumb([
  { name: "Início", url: "/" },
  { name: "Contato", url: "/contato" },
]);
---

<Layout
  title="Contato | Palato do Côa Brasil"
  description="Entre em contato com o Palato do Côa para compras atacado, distribuição, visitas à quinta e parcerias no Brasil. Respondemos em até 48 horas."
  schema={schema}
>
  <section class="py-20 px-6 border-b border-[var(--color-border)] text-center">
    <p class="section-subtitle">Fale Connosco</p>
    <h1 class="section-title">Entre em Contato</h1>
    <div class="divider-gold mx-auto"></div>
    <p class="text-sm text-[var(--color-muted)] max-w-2xl mx-auto leading-relaxed mt-4">
      Estamos aqui para atender você com a mesma dedicação que colocamos em cada garrafa.
      Quer levar os vinhos Palato do Côa para o seu restaurante, importadora, adega, hotel ou negócio?
      Nossa equipe está pronta para oferecer condições especiais de atacado, suporte completo —
      fichas técnicas, fotos, treinamento de sommeliers — e atendimento personalizado.
    </p>
  </section>

  <section class="py-16 px-6 max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Sidebar -->
    <aside class="space-y-8">
      {[
        {
          title: "Atacado",
          text: "Condições especiais para restaurantes, adegas e distribuidores. Volume mínimo e logística dedicada.",
        },
        {
          title: "Visita à Quinta",
          text: "Programa exclusivo para parceiros brasileiros — visita, prova guiada e reunião comercial no Douro Superior.",
        },
        {
          title: "Distribuição",
          text: "Procuramos parceiros exclusivos de distribuição em todo o território brasileiro.",
        },
      ].map((item) => (
        <div class="border-l-2 border-[var(--color-gold)] pl-4">
          <h3 class="font-serif text-lg mb-1">{item.title}</h3>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.text}</p>
        </div>
      ))}

      <div class="border-t border-[var(--color-border)] pt-6 space-y-2">
        <p class="text-xs uppercase tracking-widest text-[var(--color-gold)] mb-3">Contato directo</p>
        <a href="mailto:brasil@palatodocoa.pt" class="block text-sm hover:text-[var(--color-gold)] transition-colors">
          brasil@palatodocoa.pt
        </a>
        <a href="https://www.instagram.com/palatodocoa.brasil" target="_blank" rel="noopener"
           class="block text-sm hover:text-[var(--color-gold)] transition-colors">
          @palatodocoa.brasil
        </a>
        <a
          href="https://wa.me/5511939149381?text=Olá!%20Gostaria%20de%20mais%20informações%20sobre%20os%20vinhos%20Palato%20do%20Côa%20para%20meu%20restaurante%20ou%20negócio."
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 mt-4 px-4 py-3 bg-[#25D366] text-white text-sm font-medium hover:bg-[#1ebe5d] transition-colors"
        >
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Falar no WhatsApp
        </a>
      </div>

      <div class="border-t border-[var(--color-border)] pt-6">
        <p class="text-xs uppercase tracking-widest text-[var(--color-gold)] mb-3">Localização</p>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-2">
          🇧🇷 Brasil — atendimento nacional
        </p>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          🇵🇹 Portugal — Quinta da Saudade,<br />Muxagata, Douro Superior
        </p>
        <p class="text-xs text-[var(--color-muted)] mt-4 italic">
          Estamos ansiosos para construir uma parceria de longo prazo com você.
        </p>
      </div>
    </aside>

    <!-- Formulário -->
    <div class="md:col-span-2">
      <ContactForm />
    </div>
  </section>
</Layout>
