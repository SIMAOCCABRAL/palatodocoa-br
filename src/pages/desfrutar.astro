---
import Layout from "../layouts/Layout.astro";
import { schemaBreadcrumb } from "../lib/seo";

const meta = {
  essencia: {
    subtitle: "Nossa Essência",
    title: "Essência | Palato do Côa",
    description: "Conheça a história, valores e família por trás do Palato do Côa — projeto vinícola familiar do Douro Superior desde 2002.",
    h1: "A nossa essência",
    intro: "Nascemos da paixão por vinhos com alma. Uma família do Douro Superior que decidiu traduzir a singularidade do seu terroir numa linguagem universal: o vinho.",
    sections: [
      { title: "Palato do Côa", text: "O nome é uma homenagem ao rio Côa, afluente do Douro que define a personalidade do nosso território. Uma escolha que marca a identidade inconfundível dos nossos vinhos." },
      { title: "Valores", text: "Qualidade sem concessões, respeito pelo terroir e pela natureza, e uma visão de longo prazo que privilegia a excelência em cada garrafa." },
      { title: "Família", text: "Um projeto de família. Pais, filhos e enólogos que partilham a mesma paixão e o mesmo compromisso com a excelência vitivinícola." },
    ],
  },
  criar: {
    subtitle: "Viticultura & Enologia",
    title: "Criar | Palato do Côa",
    description: "Conheça a Quinta, a viticultura e a enologia por trás dos vinhos Palato do Côa no Douro Superior.",
    h1: "A arte de criar",
    intro: "Do xisto ao copo — a criação de um vinho Palato do Côa é uma jornada de rigor, paciência e paixão pela terra do Douro Superior.",
    sections: [
      { title: "A Quinta", text: "Localizada no Douro Superior, a nossa quinta beneficia de condições únicas: amplitude térmica elevada, solos de xisto e exposição solar generosa que concentram sabor e personalidade nas uvas." },
      { title: "Viticultura", text: "Agricultura cuidada, respeito pelos ciclos naturais e vindima maioritariamente manual. Cada cepa é tratada como um elemento único do ecossistema da quinta." },
      { title: "Enologia", text: "Uma equipa de enólogos apaixonados que combina tradição e inovação, procurando sempre expressar o máximo potencial do terroir sem o subjugar." },
    ],
  },
  desfrutar: {
    subtitle: "Enoturismo",
    title: "Enoturismo | Palato do Côa",
    description: "Visite a Quinta Palato do Côa no Douro Superior. Experiências de enoturismo para grupos, restaurantes e parceiros brasileiros.",
    h1: "Desfrutar o Douro",
    intro: "A experiência Palato do Côa vai além do copo. Venha ao Douro Superior descobrir de onde vem a alma dos nossos vinhos.",
    sections: [
      { title: "Visita à Quinta", text: "Percorra as vinhas, conheça a adega e participe numa prova guiada. Uma experiência sensorial única no coração do Douro Superior." },
      { title: "Para Parceiros Brasileiros", text: "Programas especiais para importadores, sommeliers e profissionais do setor de gastronomia e hospitalidade do Brasil." },
      { title: "Reservas", text: "Visitas mediante marcação. Entre em contato para planear a sua visita e conhecer todas as opções disponíveis." },
    ],
  },
}[Astro.url.pathname.replace("/", "")] || {};

const slug = Astro.url.pathname.replace("/", "");
const schema = schemaBreadcrumb([
  { name: "Início", url: "/" },
  { name: meta.h1 || slug, url: "/" + slug },
]);
---

<Layout title={meta.title} description={meta.description} schema={schema}>
  <section class="py-20 px-6 border-b border-[var(--color-border)] text-center">
    <p class="section-subtitle">{meta.subtitle}</p>
    <h1 class="section-title">{meta.h1}</h1>
    <div class="divider-gold mx-auto"></div>
    <p class="text-sm text-[var(--color-muted)] max-w-xl mx-auto">{meta.intro}</p>
  </section>

  <section class="py-16 px-6 max-w-5xl mx-auto space-y-16">
    {meta.sections?.map((s: {title: string, text: string}) => (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 border-b border-[var(--color-border)] pb-12">
        <div>
          <h2 class="font-serif text-2xl">{s.title}</h2>
          <div class="divider-gold mt-4"></div>
        </div>
        <div class="md:col-span-2">
          <p class="text-[var(--color-muted)] leading-relaxed">{s.text}</p>
        </div>
      </div>
    ))}
  </section>

  <section class="py-16 px-6 text-center bg-white border-t border-[var(--color-border)]">
    <h2 class="font-serif text-2xl mb-4">Quer saber mais?</h2>
    <p class="text-sm text-[var(--color-muted)] mb-8">Entre em contato ou descubra os nossos vinhos.</p>
    <div class="flex gap-4 justify-center">
      <a href="/contato" class="btn-secondary">Falar connosco</a>
      <a href="/beber" class="btn-primary">Ver vinhos</a>
    </div>
  </section>
</Layout>
