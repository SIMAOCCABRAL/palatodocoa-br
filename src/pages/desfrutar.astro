---
import Layout from "../layouts/Layout.astro";
import { schemaBreadcrumb } from "../lib/seo";
const schema = schemaBreadcrumb([{ name: "Início", url: "/" }, { name: "Enoturismo", url: "/desfrutar" }]);
---
<Layout
  title="Enoturismo no Douro Superior | Palato do Côa"
  description="Visite a Quinta Palato do Côa no Douro Superior. Experiências de enoturismo para grupos, restaurantes e parceiros brasileiros. Vindima, provas guiadas e muito mais."
  schema={schema}
>
  <section class="py-20 px-6 border-b border-[var(--color-border)] text-center">
    <p class="section-subtitle">Enoturismo</p>
    <h1 class="section-title">Venha ao Douro</h1>
    <div class="divider-gold mx-auto"></div>
    <p class="text-sm text-[var(--color-muted)] max-w-xl mx-auto leading-relaxed">
      A experiência Palato do Côa vai além do copo. Venha descobrir de onde vem
      a alma dos nossos vinhos — e leve uma história para contar.
    </p>
  </section>

  <section class="py-16 px-6 max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
      {[
        { icon: "🍇", title: "Visita à Quinta", text: "Percorra as vinhas, conheça as castas e entenda como o xisto do Douro Superior dá vida a vinhos únicos." },
        { icon: "🍷", title: "Prova Guiada", text: "Prove 4 a 6 vinhos com explicação do enólogo. Uma viagem pelos aromas, sabores e histórias de cada rótulo." },
        { icon: "🌄", title: "Paisagem UNESCO", text: "O Vale do Douro é Património Mundial. Vistas que ficam para sempre — e vinhos à altura da paisagem." },
      ].map((item) => (
        <div class="border border-[var(--color-border)] p-8 text-center hover:border-[var(--color-gold)] transition-colors">
          <div class="text-4xl mb-4">{item.icon}</div>
          <h3 class="font-serif text-xl mb-3">{item.title}</h3>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center py-12 border-t border-[var(--color-border)]">
      <div>
        <p class="section-subtitle">Para Brasileiros</p>
        <h2 class="font-serif text-3xl mb-4">Programa especial Brasil</h2>
        <div class="divider-gold"></div>
        <p class="text-[var(--color-muted)] leading-relaxed mb-4">
          Temos um programa pensado para importadores, sommeliers, donos de restaurante e
          profissionais de gastronomia brasileiros que queiram conhecer a nossa quinta pessoalmente.
        </p>
        <ul class="space-y-2 text-sm text-[var(--color-muted)] mb-6">
          {["Visita guiada completa à quinta e adega", "Prova de 6 vinhos com harmonização", "Reunião técnica e comercial", "Certificado de visita", "Condições exclusivas de importação"].map((item) => (
            <li class="flex items-center gap-2">
              <span class="text-[var(--color-gold)]">→</span> {item}
            </li>
          ))}
        </ul>
        <a href="/contato?interesse=visita" class="btn-secondary">Reservar visita</a>
      </div>
      <div class="bg-[var(--color-border)] h-80 flex items-center justify-center">
        <span class="text-xs uppercase tracking-widest text-[var(--color-muted)]">Foto da visita / prova</span>
      </div>
    </div>

    <div class="mt-16 p-8 bg-[var(--color-cream)] border border-[var(--color-border)] text-center">
      <p class="section-subtitle">Vindima</p>
      <h2 class="font-serif text-2xl mb-3">Setembro & Outubro</h2>
      <p class="text-sm text-[var(--color-muted)] max-w-xl mx-auto mb-6">
        A experiência mais intensa do Douro. Participe na apanha das uvas, pise o lagar
        e viva a vindima por dentro. Uma memória para toda a vida.
      </p>
      <a href="/contato?interesse=visita" class="btn-primary">Saber mais</a>
    </div>
  </section>
</Layout>
