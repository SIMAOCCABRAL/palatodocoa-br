---
import Layout from "../layouts/Layout.astro";
import { schemaOrganization, SITE } from "../lib/seo";
import { getCollection } from "astro:content";

const featuredWines = await getCollection("wines", ({ data }) => data.featured);
const schema = schemaOrganization();
---

<Layout
  title="Palato do Côa | Vinhos Douro Superior para Restaurantes e Importadoras"
  description="Vinhos premium do Douro Superior disponíveis no Brasil em atacado. Condições especiais para restaurantes, importadoras, distribuidores e adegas. Diferencie sua carta de vinhos."
  keywords={`${SITE.keywords.b2b}, ${SITE.keywords.b2c}, ${SITE.keywords.brand}`}
  schema={schema}
>

  <!-- ── HERO ── -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-[var(--color-dark)]">
    <img src="/images/hero/hero-quinta.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover object-center opacity-40" />
    <div class="relative z-10 text-center text-white px-6 max-w-3xl mx-auto animate-fade-in">
      <p class="text-xs uppercase tracking-[0.4em] text-[var(--color-gold)] mb-6">
        Douro Superior · Portugal
      </p>
      <h1 class="font-serif text-5xl md:text-7xl leading-tight mb-8">
        Palato do Côa – Douro Superior
      </h1>
      <p class="text-base md:text-lg text-gray-300 leading-relaxed mb-4 max-w-2xl mx-auto">
        Nascemos em 2007 na Quinta da Saudade, em Muxagata — no coração do Douro Superior.
        Vinhos feitos 100% com uvas da nossa propriedade, com o xisto, o sol e a alma do Vale do Côa.
      </p>
      <p class="text-base md:text-lg text-gray-300 leading-relaxed mb-10 max-w-2xl mx-auto">
        Agora disponíveis para restaurantes, importadoras e distribuidores no Brasil.
        Condições especiais de atacado, suporte completo e uma história real por trás de cada rótulo.
      </p>
      <p class="font-serif text-xl text-[var(--color-gold)] italic mb-10">
        "Bons amigos, bons vinhos, bons momentos."
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/para-o-brasil" class="btn-secondary">Oportunidade no Brasil →</a>
        <a href="/vinhos" class="btn-primary border-white text-white hover:bg-white hover:text-[var(--color-dark)]">
          Ver os vinhos
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40 animate-bounce">
      <span class="text-[10px] uppercase tracking-widest">Explorar</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ── POR QUE ESCOLHER PALATO DO CÔA ── -->
  <section class="py-24 px-6 max-w-5xl mx-auto text-center">
    <p class="section-subtitle">Proposta de valor</p>
    <h2 class="section-title">Por que escolher Palato do Côa</h2>
    <div class="divider-gold mx-auto"></div>
    <p class="text-[var(--color-muted)] leading-relaxed max-w-2xl mx-auto mb-6">
      Palato do Côa nasce de uma paixão compartilhada por seis amigos que, em 2007, decidiram
      investir no melhor terroir do Douro Superior. Hoje, esses vinhos chegam ao Brasil para quem
      valoriza <strong>autenticidade, elegância e história em cada garrafa</strong>.
    </p>
    <p class="text-[var(--color-muted)] leading-relaxed max-w-2xl mx-auto mb-10">
      O Palato do Côa oferece ao mercado brasileiro vinhos com identidade própria do Douro Superior,
      produção controlada e excelente relação qualidade-preço. Atendemos com condições diferenciadas
      de atacado, logística dedicada e materiais de apoio para sua equipe de vendas e sommeliers.
    </p>
    <a href="/essencia" class="btn-primary">Conhecer a nossa história</a>
  </section>

  <!-- ── 3 PILARES ── -->
  <section class="py-16 bg-white px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: "🪨",
            title: "Terroir único do Douro Superior",
            text: "Altitude elevada, solo de xisto e amplitude térmica extrema criam vinhos com mineralidade e elegância impossíveis de replicar. Um terroir que conta história em cada taça.",
          },
          {
            icon: "🍇",
            title: "100% uvas da propriedade",
            text: "Todos os vinhos Palato do Côa são produzidos exclusivamente com uvas da Quinta da Saudade, em Muxagata. Controlo total da qualidade, do xisto ao copo.",
          },
          {
            icon: "🏆",
            title: "Vantagens competitivas para B2B",
            text: "Fichas técnicas, fotos profissionais, treinamento de equipe e suporte completo. Tudo para você vender mais com vinhos que têm história para contar.",
          },
        ].map((item) => (
          <div class="text-center p-8 border border-[var(--color-border)] hover:border-[var(--color-gold)] transition-colors">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="font-serif text-xl mb-3">{item.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── VINHOS DESTAQUE ── -->
  {featuredWines.length > 0 && (
    <section class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <p class="section-subtitle">Vinho douro superior atacado</p>
          <h2 class="section-title">Nossos Vinhos</h2>
          <div class="divider-gold mx-auto"></div>
          <p class="text-sm text-[var(--color-muted)] max-w-xl mx-auto mt-4">
            Palato do Côa Branco, Tinto e Vinhas do Côa — disponíveis para restaurantes,
            importadoras e adegas em todo o Brasil.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featuredWines.slice(0, 3).map((wine) => (
            <a href={`/vinhos/${wine.id}`} class="group border border-[var(--color-border)] p-6 hover:border-[var(--color-gold)] transition-all bg-white">
              <p class="text-xs uppercase tracking-widest text-[var(--color-gold)] mb-2">
                {wine.data.type} · Douro Superior
              </p>
              <h3 class="font-serif text-xl group-hover:text-[var(--color-gold)] transition-colors mb-2">
                {wine.data.title}
              </h3>
              <p class="text-sm text-[var(--color-muted)] line-clamp-3">{wine.data.description}</p>
              <p class="text-xs uppercase tracking-widest mt-4 group-hover:text-[var(--color-gold)] transition-colors">
                Ver ficha técnica →
              </p>
            </a>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/vinhos" class="btn-primary">Ver todos os vinhos</a>
        </div>
      </div>
    </section>
  )}

  <!-- ── OPORTUNIDADE NO BRASIL ── -->
  <section class="py-24 px-6 bg-[var(--color-dark)] text-white">
    <div class="max-w-3xl mx-auto text-center">
      <p class="section-subtitle text-[var(--color-gold)]">Oportunidade no Brasil</p>
      <h2 class="font-serif text-4xl md:text-5xl mb-6">
        Diferencie sua carta de vinhos com o Douro Superior
      </h2>
      <div class="divider-gold mx-auto"></div>
      <p class="text-gray-300 leading-relaxed mb-10 max-w-xl mx-auto">
        Atendemos restaurantes, importadoras, adegas e distribuidores com condições especiais
        de atacado, logística dedicada e suporte completo para sua equipe.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/para-o-brasil" class="btn-secondary">Como se tornar parceiro</a>
        <a href="/contato" class="btn-primary border-white text-white hover:bg-white hover:text-[var(--color-dark)]">
          Falar com nossa equipe
        </a>
      </div>
    </div>
  </section>

</Layout>
