---
import Layout from "../../layouts/Layout.astro";
import WineCard from "../../components/ui/WineCard.astro";
import { getCollection } from "astro:content";
import { schemaBreadcrumb } from "../../lib/seo";

const allWines = await getCollection("wines");
const byLine = {
  "palato-do-coa": allWines.filter((w) => w.data.line === "palato-do-coa"),
  "vinhas-do-coa": allWines.filter((w) => w.data.line === "vinhas-do-coa"),
  "edicoes-especiais": allWines.filter((w) => w.data.line === "edicoes-especiais"),
};

const schema = schemaBreadcrumb([
  { name: "Início", url: "/" },
  { name: "Vinhos", url: "/beber" },
]);
---

<Layout
  title="Vinhos | Palato do Côa"
  description="Descubra os vinhos Palato do Côa e Vinhas do Côa — brancos, tintos e rosés do Douro Superior disponíveis para o mercado brasileiro."
  schema={schema}
>
  <!-- Hero -->
  <section class="py-20 px-6 text-center border-b border-[var(--color-border)]">
    <p class="section-subtitle">Douro Superior, Portugal</p>
    <h1 class="section-title">Os nossos vinhos</h1>
    <div class="divider-gold mx-auto"></div>
    <p class="text-sm text-[var(--color-muted)] max-w-xl mx-auto">
      Três linhas, um terroir único. Cada vinho conta a história de uma família
      apaixonada pelo Douro Superior.
    </p>
  </section>

  <!-- Linhas -->
  {(Object.entries(byLine) as [string, typeof allWines][]).map(([line, wines]) => wines.length > 0 && (
    <section class="py-16 px-6 max-w-7xl mx-auto">
      <h2 class="font-serif text-2xl mb-2">
        {line === "palato-do-coa" ? "Palato do Côa" :
         line === "vinhas-do-coa" ? "Vinhas do Côa" : "Edições Especiais"}
      </h2>
      <div class="divider-gold mb-10"></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {wines.map((wine) => (
          <WineCard
            title={wine.data.title}
            subtitle={wine.data.subtitle}
            type={wine.data.type}
            line={wine.data.line}
            description={wine.data.description}
            image={wine.data.image}
            slug={wine.slug}
          />
        ))}
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-16 px-6 text-center bg-white border-t border-[var(--color-border)]">
    <p class="section-subtitle">Compra Atacado</p>
    <h2 class="font-serif text-3xl mb-4">Interesse em distribuição?</h2>
    <p class="text-sm text-[var(--color-muted)] max-w-md mx-auto mb-8">
      Condições especiais para restaurantes, importadoras e adegas no Brasil.
    </p>
    <a href="/contato" class="btn-secondary">Solicitar orçamento</a>
  </section>
</Layout>
