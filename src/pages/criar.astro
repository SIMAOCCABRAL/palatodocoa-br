---
import Layout from "../layouts/Layout.astro";
import { schemaBreadcrumb } from "../lib/seo";
const schema = schemaBreadcrumb([{ name: "Início", url: "/" }, { name: "Criar", url: "/criar" }]);
---
<Layout
  title="Viticultura & Enologia | Palato do Côa"
  description="Da videira ao copo — conheça a quinta, a viticultura e a enologia por trás dos vinhos Palato do Côa no Douro Superior."
  schema={schema}
>
  <section class="py-20 px-6 border-b border-[var(--color-border)] text-center">
    <p class="section-subtitle">Da Vinha ao Copo</p>
    <h1 class="section-title">A Arte de Criar</h1>
    <div class="divider-gold mx-auto"></div>
    <p class="text-sm text-[var(--color-muted)] max-w-xl mx-auto leading-relaxed">
      Criar um vinho é um ato de paciência e de escuta. Escutar o terroir, as estações, a vinha.
      No Douro Superior, aprendemos que a natureza já faz a maior parte do trabalho.
    </p>
  </section>

  <section class="py-16 px-6 max-w-5xl mx-auto space-y-20">
    {[
      {
        subtitle: "O Lugar",
        title: "A Quinta",
        text1: "Localizada no Douro Superior, a nossa quinta estende-se por terraços de xisto que sobem da margem do Côa até às cumeadas. Aqui, a paisagem foi moldada por gerações de viticultores que souberam ler o terroir e adaptar-se a um dos ambientes mais exigentes de Portugal.",
        text2: "A altitude varia entre 400 e 650 metros, o que cria diferenças de microclima que se refletem diretamente na personalidade dos vinhos de cada parcela.",
        imgLabel: "Foto da quinta / terraços",
        reverse: false,
      },
      {
        subtitle: "No Campo",
        title: "Viticultura",
        text1: "Praticamos uma viticultura de intervenção mínima — deixamos a vinha expressar-se sem a forçar. As vindimas são feitas maioritariamente à mão, de madrugada, para preservar os aromas e a frescura das uvas.",
        text2: "Trabalhamos com as grandes castas autóctones do Douro: Touriga Nacional, Touriga Franca, Tinta Roriz, Rabigato, Gouveio e Viosinho. Cada uma tem o seu terroir preferido dentro da quinta.",
        imgLabel: "Foto das vinhas / vindima",
        reverse: true,
      },
      {
        subtitle: "Na Adega",
        title: "Enologia",
        text1: "Na adega, o nosso trabalho é preservar o que a natureza deu — e aperfeiçoar apenas o que é necessário. Fermentações longas, estágios em barricas de carvalho francês para as linhas de topo, e um processo de decisão que privilegia sempre a elegância sobre a potência bruta.",
        text2: "O resultado são vinhos que refletem o ano, o terroir e a casta — não um estilo imposto. Vinhos honestos, com caráter e com a capacidade de envelhecer graciosamente.",
        imgLabel: "Foto da adega / barricas",
        reverse: false,
      },
    ].map((section) => (
      <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 items-center pb-16 border-b border-[var(--color-border)]`}>
        <div class={section.reverse ? "order-1 md:order-2" : ""}>
          <p class="section-subtitle">{section.subtitle}</p>
          <h2 class="font-serif text-3xl mb-4">{section.title}</h2>
          <div class="divider-gold"></div>
          <p class="text-[var(--color-muted)] leading-relaxed mb-4">{section.text1}</p>
          <p class="text-[var(--color-muted)] leading-relaxed">{section.text2}</p>
        </div>
        <div class={`bg-[var(--color-border)] h-72 flex items-center justify-center ${section.reverse ? "order-2 md:order-1" : ""}`}>
          <span class="text-xs uppercase tracking-widest text-[var(--color-muted)]">{section.imgLabel}</span>
        </div>
      </div>
    ))}
  </section>

  <section class="py-16 px-6 text-center">
    <h2 class="font-serif text-3xl mb-4">Conheça os vinhos</h2>
    <p class="text-sm text-[var(--color-muted)] mb-8 max-w-md mx-auto">O resultado de todo este processo está em cada garrafa.</p>
    <div class="flex gap-4 justify-center">
      <a href="/beber" class="btn-secondary">Ver vinhos</a>
      <a href="/contato" class="btn-primary">Solicitar orçamento</a>
    </div>
  </section>
</Layout>
