---
interface Props {
  title: string;
  subtitle?: string;
  type: string;
  line: string;
  description: string;
  image?: string;
  slug: string;
}
const { title, subtitle, type, description, image, slug } = Astro.props;

const typeLabel: Record<string, string> = {
  tinto: "Tinto",
  branco: "Branco",
  rose: "Rosé",
};
---

<article class="group border border-[var(--color-border)] bg-white hover:shadow-lg transition-all duration-300">
  <a href={`/vinhos/${slug}`} class="block">
    <!-- Imagem -->
    <div class="relative overflow-hidden bg-[var(--color-cream)] h-72 flex items-center justify-center">
      {image ? (
        <img
          src={image}
          alt={`Garrafa de ${typeLabel[type] || type} ${title} - Douro Superior Portugal`}
          class="h-60 w-auto object-contain mx-auto group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="flex flex-col items-center gap-2 text-[var(--color-border)]">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
              d="M9 3v7.5a3 3 0 006 0V3M6 3h12M8 21h8M12 13v8" />
          </svg>
          <span class="text-xs uppercase tracking-widest">{typeLabel[type] || type}</span>
        </div>
      )}
      <span class="absolute top-3 left-3 text-[10px] uppercase tracking-widest bg-white px-2 py-1 text-[var(--color-gold)]">
        {typeLabel[type] || type}
      </span>
    </div>

    <!-- Info -->
    <div class="p-6">
      <h3 class="font-serif text-xl text-[var(--color-dark)] mb-1 group-hover:text-[var(--color-gold)] transition-colors">
        {title}
      </h3>
      {subtitle && (
        <p class="text-xs uppercase tracking-widest text-[var(--color-gold)] mb-3">{subtitle}</p>
      )}
      <p class="text-sm text-[var(--color-muted)] leading-relaxed line-clamp-3">{description}</p>
      <p class="text-xs uppercase tracking-widest mt-4 text-[var(--color-dark)] group-hover:text-[var(--color-gold)] transition-colors">
        Ver detalhes →
      </p>
    </div>
  </a>
</article>
