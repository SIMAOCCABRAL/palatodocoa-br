# ── Google Analytics 4 ──
# Obtém em: analytics.google.com → Administrador → Streams de dados
PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Meta (Facebook/Instagram) Pixel ──
# Obtém em: business.facebook.com → Gestor de Eventos
PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXX

# ── TikTok Pixel ──
# Obtém em: ads.tiktok.com → Biblioteca de Ativos → Eventos
PUBLIC_TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXX

# ── Google Tag Manager (opcional — alternativa ao GA4 directo) ──
PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Pinterest Tag (opcional) ──
PUBLIC_PINTEREST_TAG_ID=XXXXXXXXXXXXXXXXX
